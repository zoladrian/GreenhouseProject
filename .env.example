# Skopiuj do .env i dostosuj (Docker Compose wczytuje .env automatycznie):
#   cp .env.example .env

# Ścieżka na hoście do koordynatora Zigbee (lewa strona mapowania `devices` w compose).
# Sprawdź: ls -la /dev/ttyUSB* /dev/ttyACM* /dev/serial/by-id/
# Stabilniejsze po reboocie: pełna ścieżka z by-id, np.:
#   ZIGBEE_DEVICE=/dev/serial/by-id/usb-Silicon_Labs_Sonoff_Zigbee_3.0_USB_Dongle_Plus_...
ZIGBEE_DEVICE=/dev/ttyACM0

# Alternatywy częste na Pi: /dev/ttyUSB0
# Jeśli używasz własnego symlinka udev (np. /dev/ttyUSBZigbee), ustaw go tutaj.

# Sekret API dla mutacji (POST/PUT/DELETE). WYMAGANY w produkcji.
# Wygeneruj losowy sekret (Linux/Mac):
#   openssl rand -hex 24
# albo (PowerShell na Windows):
#   -join ((48..57)+(97..122) | Get-Random -Count 48 | %% {[char]$_})
# Min. 16 znaków, NIE używaj słów "change-me", "dev-only", "secret", "api-key".
GREENHOUSE_API_KEY=zmien-na-losowy-min-16-znakow
