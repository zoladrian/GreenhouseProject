{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Infrastructure": {
    "DatabasePath": "data/greenhouse.db"
  },
  "Mqtt": {
    "Enabled": true,
    "Host": "localhost",
    "Port": 1883,
    "TopicFilter": "zigbee2mqtt/#"
  },
  "Voice": {
    "GreetingLeadin": "Dzień dobry Panie Czesławie",
    "TimeZoneId": "Europe/Warsaw"
  },
  "WeatherInterpretation": {
    "DewIntensityMax": 8,
    "LightRainIntensityMin": 12,
    "ModerateRainIntensityMin": 35,
    "HeavyRainIntensityMin": 70,
    "NightLightRawMax": 60,
    "DarkOrOvercastRawMax": 280,
    "BrightRawMax": 700,
    "SunnyRawMax": 1200,
    "DewMaxMinutes": 35
  },
  "AllowedHosts": "*"
}
